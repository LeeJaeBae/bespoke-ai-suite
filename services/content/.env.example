# Server Configuration
PORT=8081
HOST=0.0.0.0
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=bespoke_content
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_IDLE_TIME=10000

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m

# Crew AI Configuration
CREW_AI_BASE_URL=http://localhost:8000
CREW_AI_API_KEY=your-crew-ai-api-key
CREW_AI_TIMEOUT=30000

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=content-service
KAFKA_GROUP_ID=content-service-group

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info