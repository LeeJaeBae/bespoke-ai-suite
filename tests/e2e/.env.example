# Bespoke AI Suite E2E Test Environment Variables

# Service URLs
FRONTEND_URL=http://localhost:3005
CONTENT_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
CAMPAIGN_SERVICE_URL=http://localhost:8083
ANALYTICS_SERVICE_URL=http://localhost:8084

# Test Environment
NODE_ENV=test
TEST_RETRIES=2
TEST_TIMEOUT=30000
HEADLESS=true
SLOW_MO=0

# Performance Thresholds
LOAD_TIME_THRESHOLD=3000
API_RESPONSE_THRESHOLD=1000
BUNDLE_SIZE_THRESHOLD=2000000

# Test User Accounts
TEST_USER_EMAIL=user@bespoke.ai
TEST_USER_PASSWORD=UserTest123!
TEST_ADMIN_EMAIL=admin@bespoke.ai
TEST_ADMIN_PASSWORD=AdminTest123!
TEST_EDITOR_EMAIL=editor@bespoke.ai
TEST_EDITOR_PASSWORD=EditorTest123!

# CI/CD Configuration
CI=false
GITHUB_ACTIONS=false

# Slack Notifications (for CI)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Badge Configuration (for CI)
BADGE_GIST_ID=your-gist-id-here

# Database URLs (for cleanup operations)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/bespoke_test
MONGODB_URL=mongodb://localhost:27017/bespoke_test
REDIS_URL=redis://localhost:6379/1

# External Service URLs (for mocking)
OPENAI_API_URL=https://api.openai.com/v1
CLAUDE_API_URL=https://api.anthropic.com/v1