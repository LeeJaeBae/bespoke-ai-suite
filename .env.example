# Environment Configuration
NODE_ENV=development

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=bespoke_db

MONGODB_URI=mongodb://mongo:mongo123@localhost:27017/bespoke_content?authSource=admin
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# Vector Database (Weaviate)
WEAVIATE_URL=http://localhost:8080

# Object Storage (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=bespoke-assets

# API Keys (replace with your own)
OPENAI_API_KEY=your-openai-api-key
CLAUDE_API_KEY=your-claude-api-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# Service Ports
CONTENT_SERVICE_PORT=3001
CAMPAIGN_SERVICE_PORT=3002
USER_SERVICE_PORT=3003
ANALYTICS_SERVICE_PORT=3004

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8080

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true

# Feature Flags
ENABLE_RAG=true
ENABLE_CREW_AI=true
ENABLE_A_B_TESTING=true